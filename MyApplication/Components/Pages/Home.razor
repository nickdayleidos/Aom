@page "/"
@page "/home"
@inherits MyApplication.Components.Shared.Base.AppComponentBase
@using MyApplication.Components.Model.AOM.Tools
@using MyApplication.Components.Service.Home

<PageTitle>TOD Dashboard</PageTitle>

@if (IsLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h5" Style="flex:1">TOD Operations Dashboard</MudText>

    @if (Cache.IsRefreshing)
    {
        <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" Class="mr-2" />
        <MudText Typo="Typo.caption" Class="mud-text-secondary mr-3">Updating call stats...</MudText>
    }
    else if (Cache.LastRefreshed.HasValue)
    {
        <MudText Typo="Typo.caption" Class="mud-text-secondary mr-2">
            Stats updated @Cache.LastRefreshed.Value.ToString("h:mm tt")
        </MudText>
    }

    <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                   Size="Size.Small"
                   Tooltip="Refresh call stats &amp; schedule"
                   Disabled="Cache.IsRefreshing"
                   OnClick="ManualRefreshAsync" />
</MudStack>

@* ── KPI stat row ────────────────────────────────────────── *@
<MudGrid Spacing="3" Class="mb-4">
    <MudItem xs="6" sm="3">
        <StatCard Value="@TotalCallsToday.ToString("N0")"
                  Label="Calls Today"
                  Icon="@Icons.Material.Filled.Phone"
                  Color="Color.Primary" />
    </MudItem>
    <MudItem xs="6" sm="3">
        <StatCard Value="@AnswerRateToday"
                  Label="Answer Rate"
                  Icon="@Icons.Material.Filled.CheckCircle"
                  Color="Color.Success" />
    </MudItem>
    <MudItem xs="6" sm="3">
        <StatCard Value="@AvgAsaToday"
                  Label="Avg ASA Today"
                  Icon="@Icons.Material.Filled.Timer"
                  Color="Color.Info" />
    </MudItem>
    <MudItem xs="6" sm="3">
        <StatCard Value="@OpenOiCount.ToString()"
                  Label="Open Op Impacts"
                  Icon="@Icons.Material.Filled.Warning"
                  Color="@(OpenOiCount > 0 ? Color.Warning : Color.Default)" />
    </MudItem>
</MudGrid>

<MudGrid Spacing="3">

    @* ── 1. Call Performance — Today and MTD side by side ────────── *@
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-3" Style="height:100%">
            <MudText Typo="Typo.h6" Class="mb-2">Today</MudText>
            <MudSimpleTable Dense="true" Hover="true" Class="mb-2">
                <thead>
                    <tr>
                        <th>Queue</th>
                        <th>Offered</th>
                        <th>Answered</th>
                        <th>ASA (sec)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in _dailyStats)
                    {
                        <tr>
                            <td>@r.Queue</td>
                            <td>@r.Offered</td>
                            <td>@r.Answered</td>
                            <td>@r.Asa</td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
            @if (_dailyIntervals.Count > 0)
            {
                <MudExpansionPanels>
                    <MudExpansionPanel Text="By Interval">
                        <MudSimpleTable Dense="true" Hover="true">
                            <thead>
                                <tr>
                                    <th>Interval</th>
                                    <th>Offered</th>
                                    <th>Answered</th>
                                    <th>ASA (sec)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in _dailyIntervals)
                                {
                                    <tr>
                                        <td>@r.Label</td>
                                        <td>@r.Offered</td>
                                        <td>@r.Answered</td>
                                        <td>@r.Asa</td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    </MudExpansionPanel>
                </MudExpansionPanels>
            }
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Class="pa-3" Style="height:100%">
            <MudText Typo="Typo.h6" Class="mb-2">Month to Date</MudText>
            <MudSimpleTable Dense="true" Hover="true" Class="mb-2">
                <thead>
                    <tr>
                        <th>Queue</th>
                        <th>Offered</th>
                        <th>Answered</th>
                        <th>ASA (sec)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in _mtdStats)
                    {
                        <tr>
                            <td>@r.Queue</td>
                            <td>@r.Offered</td>
                            <td>@r.Answered</td>
                            <td>@r.Asa</td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
            @if (_mtdByDate.Count > 0)
            {
                <MudExpansionPanels>
                    <MudExpansionPanel Text="By Date">
                        <MudSimpleTable Dense="true" Hover="true">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Offered</th>
                                    <th>Answered</th>
                                    <th>ASA (sec)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in _mtdByDate)
                                {
                                    <tr>
                                        <td>@r.Date.ToString("MM/dd")</td>
                                        <td>@r.Offered</td>
                                        <td>@r.Answered</td>
                                        <td>@r.Asa</td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    </MudExpansionPanel>
                </MudExpansionPanels>
            }
        </MudPaper>
    </MudItem>

    @* ── 2 & 3. Attendance & Resourcing ──────────────────────────── *@
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-0" Style="height:100%">
            <MudExpansionPanels>
                <MudExpansionPanel>
                    <TitleContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Style="width:100%">
                            <MudText Typo="Typo.h6" Style="flex:1">Attendance Today</MudText>
                            @if (_attendance.Count > 0)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Class="mr-2">
                                    @(_attendance.Sum(r => r.Count)) employees
                                </MudChip>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption" Class="mud-text-secondary mr-2">None</MudText>
                            }
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
                        @if (_attendance.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">No attendance events scheduled for today.</MudText>
                        }
                        else
                        {
                            <MudSimpleTable Dense="true" Hover="true">
                                <thead>
                                    <tr>
                                        <th>Activity</th>
                                        <th style="text-align:right">Employees</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var r in _attendance)
                                    {
                                        <tr>
                                            <td>@r.SubTypeName</td>
                                            <td style="text-align:right">@r.Count</td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        }
                    </ChildContent>
                </MudExpansionPanel>
            </MudExpansionPanels>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Class="pa-0" Style="height:100%">
            <MudExpansionPanels>
                <MudExpansionPanel>
                    <TitleContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Style="width:100%">
                            <MudText Typo="Typo.h6" Style="flex:1">Resourcing Today</MudText>
                            @if (_resourcing.Count > 0)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Class="mr-2">
                                    @(_resourcing.Sum(r => r.Count)) employees
                                </MudChip>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption" Class="mud-text-secondary mr-2">None</MudText>
                            }
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
                        @if (_resourcing.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">No resourcing events scheduled for today.</MudText>
                        }
                        else
                        {
                            <MudSimpleTable Dense="true" Hover="true">
                                <thead>
                                    <tr>
                                        <th>Activity</th>
                                        <th style="text-align:right">Employees</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var r in _resourcing)
                                    {
                                        <tr>
                                            <td>@r.SubTypeName</td>
                                            <td style="text-align:right">@r.Count</td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        }
                    </ChildContent>
                </MudExpansionPanel>
            </MudExpansionPanels>
        </MudPaper>
    </MudItem>

    @* ── 4. Upcoming Events ───────────────────────────────────────── *@
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-3" Style="height:100%">
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                <MudText Typo="Typo.h6" Style="flex:1">Upcoming Events</MudText>
                @if (_canEdit)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Add"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   Tooltip="Add Event"
                                   OnClick="OpenAddEventDialogAsync" />
                }
            </MudStack>

            @if (_upcomingEvents.Count == 0)
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary">No upcoming events.</MudText>
            }
            else
            {
                <MudSimpleTable Dense="true" Hover="true">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Title</th>
                            <th>Description</th>
                            @if (_canEdit) { <th></th> }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var evt in _upcomingEvents)
                        {
                            <tr>
                                <td style="white-space:nowrap">@evt.EventDate.ToString("MM/dd/yyyy")</td>
                                <td>@evt.Title</td>
                                <td>@evt.Description</td>
                                @if (_canEdit)
                                {
                                    <td style="white-space:nowrap">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                       Size="Size.Small"
                                                       OnClick="() => OpenEditEventDialogAsync(evt)" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                       Color="Color.Error"
                                                       Size="Size.Small"
                                                       OnClick="() => DeleteEventAsync(evt)" />
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
        </MudPaper>
    </MudItem>

    @* ── 5. Open Operational Impacts ─────────────────────────────── *@
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-3" Style="height:100%">
            <MudText Typo="Typo.h6" Class="mb-2">Open Operational Impacts</MudText>
            @if (_openOi.Count == 0)
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary">No open operational impacts.</MudText>
            }
            else
            {
                <MudSimpleTable Dense="true" Hover="true">
                    <thead>
                        <tr>
                            <th>Start</th>
                            <th>Ticket</th>
                            <th>Summary</th>
                            <th>Services Affected</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var oi in _openOi)
                        {
                            <tr>
                                <td style="white-space:nowrap">@oi.StartTime.ToString("MM/dd HH:mm")</td>
                                <td>@oi.TicketNumber</td>
                                <td>@oi.Summary</td>
                                <td>@oi.ServicesAffected</td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
        </MudPaper>
    </MudItem>

</MudGrid>
