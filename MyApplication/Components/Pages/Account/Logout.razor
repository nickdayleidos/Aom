@page "/Account/Logout"
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.OpenIdConnect
@inject NavigationManager Navigation

<PageTitle>Signing Out...</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16 text-center">
    <LoadingSpinner Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h5" Class="mt-4">Signing out...</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
        Please wait while we sign you out.
    </MudText>
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    protected override void OnInitialized()
    {
        // Build the post-logout redirect URI
        var returnUrl = ReturnUrl ?? "/";
        var postLogoutUri = Uri.EscapeDataString(returnUrl);

        // Redirect to Microsoft Identity sign-out endpoint
        Navigation.NavigateTo($"/MicrosoftIdentity/Account/SignOut?post_logout_redirect_uri={postLogoutUri}", forceLoad: true);
    }
}
