@page "/opera/new"
@inherits AppComponentBase
@attribute [Authorize(Roles = RoleConstants.Management)]
@using System
@using System.Linq
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using MyApplication.Components.Model.AOM.Employee
@using MyApplication.Components.Service
@using MyApplication.Common.Time
@using MyApplication.Components.Common.Time
@inject IOperaRepository Repo
@inject AomDbContext Db
@inject UserProfileService UserProfile

<MudStack Spacing="2">
    <MudPaper Class="pa-4" Outlined="true">
        @if (!string.IsNullOrWhiteSpace(_lastError))
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mb-2">
                <MudText Typo="Typo.caption">@_lastError</MudText>
            </MudAlert>
        }
        <MudStack Spacing="1">
            <MudText Typo="Typo.h5">New Opera Requests</MudText>
            <MudText Typo="Typo.caption">
                Select employees on the left, then fill in the request details on the right.
            </MudText>

            <MudGrid Spacing="3" Class="mt-2">
                @* LEFT: Employee Selection *@
                <MudItem xs="12" md="5">
                    <MudPaper Class="pa-3 h-100">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.subtitle1">Employees</MudText>

                            <MudGrid Spacing="1" Class="mt-1">
                                <MudItem xs="12" md="6">
                                    <MudTextField @bind-Value="_availableFilter"
                                                  @bind-Value:after="OnAvailableFilterChanged"
                                                  Label="Filter"
                                                  Dense="true"
                                                  Variant="Variant.Outlined"
                                                  Immediate="true"
                                                  DebounceInterval="250" />

                                    <MudList T="EmployeeOption" Dense="true" Class="mt-1" Style="max-height:380px; overflow-y:auto;">
                                        @foreach (var emp in _employeeOptions
                                                                                .Where(o => !_selectedEmployeeIds.Contains(o.Id) &&
                                                                                (string.IsNullOrWhiteSpace(_availableFilter) ||
                                                                                o.Label.Contains(_availableFilter, StringComparison.OrdinalIgnoreCase))))
                                        {
                                            <MudListItem T="EmployeeOption" Value="emp" OnClick="@(() => AddEmployee(emp.Id))">
                                                @emp.Label
                                            </MudListItem>
                                        }
                                    </MudList>
                                </MudItem>

                                <MudItem xs="12" md="6">
                                    <MudTextField @bind-Value="_selectedFilter"
                                                  Label="Filter"
                                                  Dense="true"
                                                  Variant="Variant.Outlined"
                                                  Immediate="true"
                                                  DebounceInterval="250" />

                                    <MudList T="EmployeeOption" Dense="true" Class="mt-1" Style="max-height:380px; overflow-y:auto;">
                                        @foreach (var emp in GetSelectedEmployeeOptions()
                                                                                .Where(o => string.IsNullOrWhiteSpace(_selectedFilter) ||
                                                                                o.Label.Contains(_selectedFilter, StringComparison.OrdinalIgnoreCase)))
                                        {
                                            <MudListItem T="EmployeeOption" Value="emp" OnClick="@(() => RemoveEmployee(emp.Id))">
                                                @emp.Label
                                            </MudListItem>
                                        }
                                    </MudList>
                                </MudItem>
                            </MudGrid>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                @* RIGHT: Request Details *@
                <MudItem xs="12" md="7">
                    <MudPaper Class="pa-3 h-100">
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.subtitle1">Request details</MudText>

                            <MudGrid Spacing="2">
                                <MudItem xs="12" md="3">
                                    <MudAutocomplete T="ActivityType"
                                                     Label="Type"
                                                     Value="_selectedTypeObj"
                                                     ValueChanged="OnTypeChanged"
                                                     SearchFunc="SearchTypes"
                                                     ToStringFunc="@(t => t?.Name)"
                                                     Variant="Variant.Outlined"
                                                     Dense="true"
                                                     ResetValueOnEmptyText="true"
                                                     CoerceText="true"
                                                     Required="true"
                                                     MaxItems="null"
                                                     AdornmentIcon="@Icons.Material.Outlined.Search" />
                                </MudItem>

                                <MudItem xs="12" md="3">
                                    <MudAutocomplete T="ActivitySubType"
                                                     Label="SubType"
                                                     Value="_selectedSubTypeObj"
                                                     ValueChanged="OnSubTypeChanged"
                                                     SearchFunc="SearchSubTypes"
                                                     ToStringFunc="@(s => s?.Name)"
                                                     Variant="Variant.Outlined"
                                                     Dense="true"
                                                     ResetValueOnEmptyText="true"
                                                     CoerceText="true"
                                                     Disabled="@(_typeId is null)"
                                                     Required="true"
                                                     MaxItems="null"
                                                     AdornmentIcon="@Icons.Material.Outlined.Search" />
                                </MudItem>

                                <MudItem xs="12" md="3">
                                    @* Timeframe: load from OperaTimeframe table *@
                                    <MudSelect T="int?" @bind-Value="_timeframeId" Label="Timeframe" Variant="Variant.Outlined" Dense="true" Required="true">
                                        @if (_timeframes != null)
                                        {
                                            @foreach (var tf in _timeframes)
                                            {
                                                <MudSelectItem T="int?" Value="@tf.Id">@tf.Name</MudSelectItem>
                                            }
                                        }
                                    </MudSelect>
                                </MudItem>

                                <MudItem xs="12" md="3">
                                    <MudSelect T="SiteZone?" @bind-Value="_zone"  Label="Time Zone" Variant="Variant.Outlined" Dense="true" Required="true" Disabled="@(_timeframeId == 2 || _timeframeId == 3)">
                                        <MudSelectItem T="SiteZone?" Value="@SiteZone.ET">Eastern</MudSelectItem>
                                        <MudSelectItem T="SiteZone?" Value="@SiteZone.MT">Mountain</MudSelectItem>
                                    </MudSelect>
                                </MudItem>
                            </MudGrid>

                            <MudDivider Class="my-1" />
                            <MudText Typo="Typo.body2">When</MudText>

                            <MudGrid Spacing="2" Class="mt-1">
                                <MudItem xs="12" md="4">
                                    <MudDatePicker @bind-Date="_startDateEt" @bind-Date:after="OnStartDateAfter" Label="Start Date" Variant="Variant.Outlined" Disabled="@(_timeframeId is null)" />
                                </MudItem>

                                <MudItem xs="12" md="4">
                                    <MudTimePicker @bind-Time="_startTimeEt"
                                    Label="Start Time"
                                    Variant="Variant.Outlined"
                                    Editable="true"
                                    Clearable="true"
                                                   Disabled="@(_timeframeId is null || _timeframeId == 2 || _timeframeId == 3 || _timeframeId == 6)" />
                                    @* For Full day single (id==2) we do not require start time selection; keep as-is when null *@
                                </MudItem>
                            </MudGrid>

                            <MudGrid Spacing="2" Class="mt-1">
                                <MudItem xs="12" md="4">
                                    <MudDatePicker @bind-Date="_endDateEt"
                                                   Label="End Date"
                                                   Variant="Variant.Outlined"
                                                   Disabled="@(_timeframeId is null || _timeframeId == 1 || _timeframeId == 2 || _timeframeId == 4 || _timeframeId == 6)" />
                                    @* Disabled for:
                                       1 = EOS (calculated)
                                       2 = Full day single (auto)
                                       4 = Timeframe single day (auto-set based on end time)
                                       Enabled only for 3 (Multiple full day) *@
                                </MudItem>

                                <MudItem xs="12" md="4">
                                    <MudTimePicker @bind-Time="_endTimeEt"
                                                   @bind-Time:after="OnEndTimeAfter"
                                                   Label="End Time"
                                                   Variant="Variant.Outlined"
                                                   Editable="true"
                                                   Clearable="true"
                                                   Disabled="@(_timeframeId is null || _timeframeId == 1 || _timeframeId == 2 || _timeframeId == 3)" />
                                    @* Enabled for:
                                       3 = Multiple full day (optional, but allowed)
                                       4 = Timeframe single day (REQUIRED)
                                       Disabled for:
                                       1 = EOS
                                       2 = Full day single (auto end-of-day) *@
                                </MudItem>
                            </MudGrid>


                            @* Overnight message for timeframe 4 *@
                            @if (_timeframeId == 4 && _overnightWarning)
                            {
                                <MudAlert Severity="Severity.Info" Dense="true">End time-of-day is earlier than start time — this will be an overnight event; end date will be auto set to the following day.</MudAlert>
                            }

                            <MudDivider Class="my-1" />
                            <MudText Typo="Typo.body2">Comments</MudText>

                            <MudTextField @bind-Value="_comments" Label="Submitter Comments" Variant="Variant.Outlined" Lines="3" FullWidth="true" />

                            <MudStack Row="true" Justify="Justify.FlexStart" Spacing="1" Class="mt-2">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SubmitAsync" Disabled="@_busy">SUBMIT</MudButton>
                                <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="@(() => Navigation.NavigateTo("/opera"))">CANCEL</MudButton>
                            </MudStack>
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudStack>
    </MudPaper>
</MudStack>

@code {
    private sealed record EmployeeOption(int Id, string Label);
    private HashSet<int> _selectedEmployeeIds = new();
    private string _availableFilter = string.Empty;
    private string _selectedFilter = string.Empty;
    private List<EmployeeOption> _employeeOptions = new();
    private readonly Dictionary<int, string> _labelCache = new();
    private CancellationTokenSource? _empCts;
    private string? _lastError;

    private List<ActivityType> _types = new();
    private List<ActivitySubType> _subTypes = new();
    private ActivityType? _selectedTypeObj;
    private ActivitySubType? _selectedSubTypeObj;
    private int? _typeId;
    private int? _subTypeId;

    // Timeframe list from DB
    private List<OperaTimeframe>? _timeframes;
    private int? _timeframeId; // binds to selected OperaTimeframe.Id

    private SiteZone? _zone;
    private DateTime? _startDateEt;
    private TimeSpan? _startTimeEt;
    private DateTime? _endDateEt;
    private TimeSpan? _endTimeEt;
    private string? _comments;
    private bool _busy;
    private bool _overnightWarning = false;

    protected override async Task OnInitializedAsync()
    {
        var now = Et.Now;
        _startDateEt = now.Date;
        _startTimeEt = now.TimeOfDay;
        _endDateEt = now.Date;
        _endTimeEt = now.TimeOfDay.Add(TimeSpan.FromHours(1));

        try
        {
            _types = await Db.ActivityTypes.AsNoTracking().Where(x => x.IsActive == true).OrderBy(x => x.Name).ToListAsync();
            _subTypes = await Db.ActivitySubTypes.AsNoTracking().Where(x => x.IsActive == true).OrderBy(x => x.Name).ToListAsync();

            // load timeframe lookup from repository (OperaTimeframe table)
            _timeframes = (await Repo.GetTimeframesAsync())?.ToList() ?? new List<OperaTimeframe>();
        }
        catch (Exception ex)
        {
            ShowError($"Failed to load lookups: {ex.Message}");
        }
        await LoadEmployeeOptionsAsync("");
    }

    private void OnStartDateAfter()
    {
        if (!_startDateEt.HasValue)
            return;

        // Safety rule: whenever start date changes, reset end date to match
        _endDateEt = _startDateEt.Value.Date;

        // Re-apply single-day overnight logic if applicable
        if (_timeframeId == 4 || _timeframeId == 6)
        {
            ApplyAutoEndDateForSingleDayTimeframes();
        }
    }

    private void OnEndTimeAfter()
    {
        if (_timeframeId == 4 || _timeframeId == 6)
            ApplyAutoEndDateForSingleDayTimeframes();
    }


    

    private void ApplyAutoEndDateForSingleDayTimeframes()
    {
        if (!(_timeframeId == 4 || _timeframeId == 6)) return;

        if (!_startDateEt.HasValue || !_endTimeEt.HasValue)
        {
            _overnightWarning = false;
            return;
        }

        // start time basis differs:
        // - TF4 uses selected start time
        // - TF6 uses computed shift start time (we'll set _startTimeEt during submission, but for UI we may not have it)
        // For UI, we can only compute overnight if we have _startTimeEt; if not, keep end date = start date until we know.
        if (!_startTimeEt.HasValue)
        {
            _endDateEt = _startDateEt.Value.Date;
            _overnightWarning = false;
            return;
        }

        var startLocal = _startDateEt.Value.Date + _startTimeEt.Value;
        var endLocal = _startDateEt.Value.Date + _endTimeEt.Value;

        if (endLocal.TimeOfDay <= startLocal.TimeOfDay)
        {
            _endDateEt = _startDateEt.Value.Date.AddDays(1);
            _overnightWarning = true;
        }
        else
        {
            _endDateEt = _startDateEt.Value.Date;
            _overnightWarning = false;
        }
    }


    private Task<IEnumerable<ActivityType>> SearchTypes(string value, CancellationToken ct)
    {
        if (string.IsNullOrEmpty(value)) return Task.FromResult<IEnumerable<ActivityType>>(_types);
        return Task.FromResult<IEnumerable<ActivityType>>(_types.Where(x => x.Name.Contains(value, StringComparison.OrdinalIgnoreCase)));
    }

    private Task<IEnumerable<ActivitySubType>> SearchSubTypes(string value, CancellationToken ct)
    {
        var filtered = _subTypes.Where(x => x.ActivityTypeId == _typeId);
        if (string.IsNullOrEmpty(value)) return Task.FromResult(filtered);
        return Task.FromResult(filtered.Where(x => x.Name.Contains(value, StringComparison.OrdinalIgnoreCase)));
    }

    private void OnTypeChanged(ActivityType? type)
    {
        _selectedTypeObj = type;
        _typeId = type?.Id;
        _selectedSubTypeObj = null;
        _subTypeId = null;
    }

    private void OnSubTypeChanged(ActivitySubType? subType)
    {
        _selectedSubTypeObj = subType;
        _subTypeId = subType?.Id;
    }

    private Task OnAvailableFilterChanged() => LoadEmployeeOptionsAsync(_availableFilter);

    private async Task LoadEmployeeOptionsAsync(string query)
    {
        _empCts?.Cancel(); _empCts?.Dispose(); _empCts = new CancellationTokenSource();
        try
        {
            var list = await Repo.SearchEmployeesAsync(query ?? "", 50, _empCts.Token) ?? Array.Empty<Employees>();
            foreach (var e in list) _labelCache[e.Id] = $"{e.LastName}, {e.FirstName} {e.MiddleInitial} (#{e.Id})";
            _employeeOptions = list.Select(e => new EmployeeOption(e.Id, _labelCache[e.Id])).ToList();
        }
        catch (OperationCanceledException) { }
        catch (Exception) { }
    }

    private IEnumerable<EmployeeOption> GetSelectedEmployeeOptions()
    {
        foreach (var id in _selectedEmployeeIds.OrderBy(i => i)) yield return new EmployeeOption(id, _labelCache.ContainsKey(id) ? _labelCache[id] : $"#{id}");
    }
    private void AddEmployee(int id) { if (_selectedEmployeeIds.Add(id)) StateHasChanged(); }
    private void RemoveEmployee(int id) { if (_selectedEmployeeIds.Remove(id)) StateHasChanged(); }

    private bool TryGetStartEndEt(out DateTime startEt, out DateTime endEt)
    {
        startEt = default; endEt = default;
        if (_timeframeId is null) return false;

        var tf = _timeframeId.Value;

        // TF2 and TF3 do NOT use _zone, so do them first and return
        if (tf == 2) // Full day (single day) - employee local 00:00 to 23:59
        {
            if (!_startDateEt.HasValue) return false;

            // dummy values; real per-employee ET conversion happens in SubmitAsync
            startEt = _startDateEt.Value.Date;
            endEt = _startDateEt.Value.Date.AddHours(23).AddMinutes(59);
            return true;
        }

        if (tf == 3) // Multiple full day - employee local 00:00 to 23:59 across dates
        {
            if (!_startDateEt.HasValue || !_endDateEt.HasValue) return false;
            if (_endDateEt.Value.Date < _startDateEt.Value.Date) return false;

            startEt = _startDateEt.Value.Date;
            endEt = _endDateEt.Value.Date.AddHours(23).AddMinutes(59);
            return true;
        }

        // For everything else, zone IS required
        if (_zone is null) return false;
        var zone = _zone.Value;

        if (tf == 1) // End of shift
        {
            if (!_startDateEt.HasValue || !_startTimeEt.HasValue) return false;
            var eosStartLocal = _startDateEt.Value.Date + _startTimeEt.Value;
            startEt = SiteTime.FromSiteToEt(eosStartLocal, zone);
            endEt = startEt.AddHours(1);
            return true;
        }

        if (tf == 4) // Timeframe single day
        {
            if (!_startDateEt.HasValue || !_startTimeEt.HasValue || !_endTimeEt.HasValue) return false;

            var startLocal = _startDateEt.Value.Date + _startTimeEt.Value;
            startEt = SiteTime.FromSiteToEt(startLocal, zone);

            var candidateLocal = _startDateEt.Value.Date + _endTimeEt.Value;
            if (candidateLocal.TimeOfDay <= startLocal.TimeOfDay)
            {
                candidateLocal = candidateLocal.AddDays(1);
                _overnightWarning = true;
            }
            else
            {
                _overnightWarning = false;
            }

            endEt = SiteTime.FromSiteToEt(candidateLocal, zone);
            return true;
        }

        if (tf == 6) // Beginning of shift: start computed later per employee, end comes from UI
        {
            if (!_startDateEt.HasValue || !_endTimeEt.HasValue) return false;

            var dummyStartLocal = _startDateEt.Value.Date;
            startEt = SiteTime.FromSiteToEt(dummyStartLocal, zone);
            endEt = startEt.AddHours(1);
            return true;
        }

        return false;
    }


    private async Task SubmitAsync()
    {
        _lastError = null;
        if (_selectedEmployeeIds.Count == 0 || _typeId == null || _subTypeId == null || _timeframeId == null)
        {
            ShowWarning("Please complete all required fields.");
            return;
        }

        // Only require zone for timeframes that actually use it
        if ((_timeframeId == 1 || _timeframeId == 4 || _timeframeId == 6) && _zone == null)
        {
            ShowWarning("Please select a Time Zone.");
            return;
        }


        if (!TryGetStartEndEt(out var startEt, out var endEt))
        {
            ShowWarning("Invalid dates/times.");
            return;
        }

        _busy = true;
        try
        {
            var profile = await UserProfile.GetAsync();
            var actor = profile.UserName ?? profile.DisplayName ?? "unknown";
            var nowEt = Et.Now;
            var requests = new List<OperaRequest>();
            var errorMessages = new List<string>();

            // For TF6 we need these UI values (local), because EndTime will be based on selected end date/time
            // _endDateEt is already being auto-updated by your form logic.
            DateTime? endLocal = null;
            if (_timeframeId == 6)
            {
                if (!_startDateEt.HasValue || !_endDateEt.HasValue || !_endTimeEt.HasValue)
                {
                    ShowWarning("Start date and end time are required for Beginning of Shift.");
                    return;
                }

                // End local datetime = (auto-updated end date) + end time
                endLocal = _endDateEt.Value.Date + _endTimeEt.Value;
            }

            Dictionary<int, string>? tzByEmp = null;

            // For TF2/TF3 we must use each employee's site TZ
            if (_timeframeId == 2 || _timeframeId == 3)
            {
                tzByEmp = await Repo.GetEmployeeSiteTimeZonesAsync(_selectedEmployeeIds.ToArray());
            }

            foreach (var empId in _selectedEmployeeIds)
            {
                // default values from TryGetStartEndEt
                DateTime finalStart = startEt;
                DateTime finalEnd = endEt;

                if (_timeframeId == 1) // End of shift: ask server for precise end-of-shift per-employee
                {
                    var eosEt = await Repo.GetEndOfShiftAsync(empId, startEt);
                    if (eosEt == null)
                    {
                        var localStart = SiteTime.FromEtToSite(startEt, _zone.Value);
                        errorMessages.Add($"No shift found for emp #{empId} at {localStart:HH:mm} ({_zone})");
                        continue;
                    }

                    finalEnd = eosEt.Value;
                }
                else if (_timeframeId == 6) // Beginning of shift: get shift start per-employee
                {
                    // We only need a date to locate the shift. Use the selected start date.
                    // Convert selected date-at-midnight local -> ET for schedule lookup.
                    var dayLocal = _startDateEt!.Value.Date;
                    var dayEt = SiteTime.FromSiteToEt(dayLocal, _zone.Value);

                    var bosEt = await Repo.GetStartOfShiftAsync(empId, dayEt);
                    if (bosEt == null)
                    {
                        errorMessages.Add($"No shift found for emp #{empId} on {dayLocal:MM/dd} ({_zone})");
                        continue;
                    }

                    finalStart = bosEt.Value;

                    // End time comes from the UI selection (local end date/time) and must be converted to ET
                    // (_endDateEt already reflects overnight logic based on selected end time)
                    finalEnd = SiteTime.FromSiteToEt(endLocal!.Value, _zone.Value);

                    // safety check
                    if (finalEnd <= finalStart)
                    {
                        var localStart = SiteTime.FromEtToSite(finalStart, _zone.Value);
                        errorMessages.Add($"End time must be after beginning-of-shift for emp #{empId} (Shift start {localStart:MM/dd HH:mm} {_zone}).");
                        continue;
                    }
                }
                else if (_timeframeId == 2 || _timeframeId == 3)
                {
                    // Employee-local full day windows:
                    // Start: 00:00 local on start date
                    // End:   23:59 local on (start date for TF2) or (end date for TF3)
                    if (!_startDateEt.HasValue)
                    {
                        errorMessages.Add($"Start date is required for emp #{empId}.");
                        continue;
                    }

                    if (_timeframeId == 3 && !_endDateEt.HasValue)
                    {
                        errorMessages.Add($"End date is required for emp #{empId}.");
                        continue;
                    }

                    var startLocal = _startDateEt.Value.Date; // 00:00
                    var endLocalDate = (_timeframeId == 2) ? _startDateEt.Value.Date : _endDateEt!.Value.Date;
                    var fullDayEndLocal = endLocalDate.AddHours(23).AddMinutes(59); // 23:59

                    var tzId = (tzByEmp != null && tzByEmp.TryGetValue(empId, out var tz)) ? tz : "Eastern Standard Time";

                    finalStart = Tz.FromSiteToEt(startLocal, tzId);
                    finalEnd = Tz.FromSiteToEt(fullDayEndLocal, tzId);
                }

                int initialStatus = (_subTypeId == 11) ? 6 : 1; // 11=Vacation -> Pending, else Submitted

                requests.Add(new OperaRequest
                {
                    EmployeeId = empId,
                    StartTime = finalStart,
                    EndTime = finalEnd,
                    SubmittedBy = actor,
                    SubmitTime = nowEt,
                    OperaStatusId = initialStatus,
                    ActivityTypeId = _typeId.Value,
                    ActivitySubTypeId = _subTypeId.Value,
                    TimeframeId = _timeframeId.Value,
                    SubmitterComments = _comments
                });
            }

            if (errorMessages.Any())
            {
                _lastError = string.Join("\n", errorMessages);
                ShowError("Some employees could not be processed (see errors).");
                return;
            }

            if (requests.Any())
            {
                await Repo.CreateManyAsync(requests);
                ShowSuccess($"Created {requests.Count} requests.");
                Navigation.NavigateTo("/opera");
            }
        }
        catch (Exception ex)
        {
            _lastError = ex.Message;
            ShowError("Error submitting request.");
        }
        finally
        {
            _busy = false;
        }
    }


    public void Dispose()
    {
        _empCts?.Cancel(); _empCts?.Dispose();
    }
}

